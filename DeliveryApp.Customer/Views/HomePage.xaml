<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Customer.Models"
             xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
             xmlns:controls="clr-namespace:DeliveryApp.Customer.Controls"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="#F8F9FA">

        <!-- ══════════════════════════════════════════════
             HEADER  (بسيط — موقع + سيرش فقط، مفيش chips)
        ══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="#FF5722" Padding="20,15,20,16"
              RowDefinitions="Auto,10,Auto" RowSpacing="0">

            <!-- Animated Logo Background (تحت كل المحتوى، بياخد مساحة الهيدر كلها)
                 ملحوظة: لازم HeightRequest ثابت هنا عشان مايبوظش قياس الـ Auto Row بحجم الصورة الأصلي (512px)
                 ملحوظة 2: AspectFit مش AspectFill عشان اللوجو يبان كامل من غير قص -->
            <Grid Grid.Row="0" Grid.RowSpan="3"
                  HorizontalOptions="Fill" VerticalOptions="Fill"
                  HeightRequest="120"
                 
                  Opacity="0.2" InputTransparent="True">
                <Image x:Name="LogoBase" Source="logo_anim_base.png"
                       Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                <Image x:Name="LogoSpeedWave" Source="logo_anim_speedwave.png"
                       Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                <Image x:Name="LogoSpeedLine" Source="logo_anim_speedline.png"
                       Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                <Image x:Name="LogoPin" Source="logo_anim_pin.png"
                       Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill"/>
            </Grid>

            <!-- Row 0: Greeting + Cart -->
            <Grid Grid.Row="0" ColumnDefinitions="*,44">
                <VerticalStackLayout Grid.Column="0" Spacing="3">

                    <!-- Location Bar (Tappable) -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLocationPickerCommand}"/>
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="📍" FontSize="15"
                               TextColor="#FFCCBC" VerticalOptions="Center"/>
                        <!-- اسم المدينة / الحي مش الإحداثيات -->
                        <Label Grid.Column="1"
                               Text="{Binding LocationLabel}"
                               FontFamily="CairoRegular" FontSize="15"
                               TextColor="#FFCCBC" VerticalOptions="Center"
                               LineBreakMode="TailTruncation" MaxLines="1"
                               Margin="4,0,4,0"/>

                    </Grid>

                    <!-- Greeting -->
                    <Label FontFamily="CairoBold" FontSize="20" TextColor="White">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding GreetingPrefix}"/>
                                <Span Text="{Binding UserName}"/>
                                <Span Text=" 👋"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <!-- Cart -->
                <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 22"
                            Stroke="Black" WidthRequest="44" HeightRequest="44">
                        <Label Text="🛒" FontSize="22"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenCartCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Border BackgroundColor="#F44336" StrokeShape="RoundRectangle 10"
                            Stroke="Black"
                            IsVisible="{Binding CartCount, Converter={StaticResource IntToBool}}"
                            WidthRequest="20" HeightRequest="20"
                            HorizontalOptions="End" VerticalOptions="Start">
                        <Label Text="{Binding CartCount}" FontFamily="CairoBold" FontSize="10"
                               TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- Search -->
            <Border Grid.Row="2" BackgroundColor="White"
                    StrokeShape="RoundRectangle 12" Stroke="Black" Padding="4,0">
                <SearchBar Placeholder="{Binding SearchHint}"
                           Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchCommand}"
                           BackgroundColor="Transparent"
                           FontFamily="CairoRegular" FontSize="14" TextColor="Black"/>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════
             BODY
        ══════════════════════════════════════════════ -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Padding="0,0,0,100" Spacing="0">

                    <!-- ── Category Icons Row (زي talabat) ── -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Margin="0,14,0,4"
                                BackgroundColor="White"
                                Padding="8,10">
                        <HorizontalStackLayout Spacing="4">
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                               CommandParameter="{x:Null}"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
             BackgroundColor="{Binding IsCatAll, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
             WidthRequest="58" HeightRequest="58"
             HorizontalOptions="Center">
                                    <Label Text="🏠" FontSize="28"
                HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_All}"
            FontFamily="CairoRegular" FontSize="11"
            TextColor="{Binding IsCatAll, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                            <!-- مطاعم -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Restaurants"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatRestaurants, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="🍽️" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Restaurants}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatRestaurants, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- طلبات مارت / بقالة -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Grocery"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatGrocery, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="🛍️" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Grocery}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatGrocery, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- صيدلية -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Pharmacy"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatPharmacy, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="💊" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Pharmacy}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatPharmacy, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- سوبر ماركت -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Supermarket"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatSupermarket, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="🏪" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Supermarket}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatSupermarket, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- خضار -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Vegetables"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatVegetables, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="🥦" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Vegetables}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatVegetables, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- مشروبات -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Drinks"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatDrinks, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="🧃" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Drinks}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatDrinks, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- اكسسوارات -->
                            <VerticalStackLayout Spacing="5" WidthRequest="72" HorizontalOptions="Center">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                          CommandParameter="Accessories"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                        BackgroundColor="{Binding IsCatAccessories, Converter={StaticResource BoolToColor}, ConverterParameter='#FFF3E0|#F5F5F5'}"
                                        WidthRequest="58" HeightRequest="58"
                                        HorizontalOptions="Center">
                                    <Label Text="👜" FontSize="28"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Cat_Accessories}"
                                       FontFamily="CairoRegular" FontSize="11"
                                       TextColor="{Binding IsCatAccessories, Converter={StaticResource BoolToColor}, ConverterParameter='#FF5722|#424242'}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- الكل -->


                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- ── Banners Carousel ── -->
                    <CarouselView x:Name="BannerCarousel"
                                  ItemsSource="{Binding Banners}"
                                  HeightRequest="160" Loop="True"
                                  IsVisible="{Binding Banners.Count, Converter={StaticResource IntToBool}}"
                                  Margin="0,12,0,0">
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="m:Banner">
                                <Grid Margin="12,0">
                                    <Border StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                            BackgroundColor="{Binding BgColor}" HeightRequest="150">
                                        <Grid ColumnDefinitions="*,Auto" Padding="20,16">
                                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="6">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="CairoBold" FontSize="18"
                                                       TextColor="White" MaxLines="2"
                                                       LineBreakMode="WordWrap"/>
                                                <Label Text="{Binding SubTitle}"
                                                       FontFamily="CairoRegular" FontSize="13"
                                                       TextColor="#FFECB3"
                                                       IsVisible="{Binding SubTitle, Converter={StaticResource HasImage}}"
                                                       MaxLines="2" LineBreakMode="WordWrap"/>
                                                <Border BackgroundColor="White"
                                                        StrokeShape="RoundRectangle 8"
                                                        Stroke="Transparent" Padding="14,6"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{loc:Loc Key=OrderNow}"
                                                           FontFamily="CairoBold" FontSize="13"
                                                           TextColor="#FF5722"/>
                                                </Border>
                                            </VerticalStackLayout>
                                            <ff:CachedImage Grid.Column="1"
                                                            Source="{Binding FullImageUrl}"
                                                            WidthRequest="100" HeightRequest="110"
                                                            Aspect="AspectFit"
                                                            IsVisible="{Binding HasImage}"
                                                            VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="🍔" FontSize="60"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   IsVisible="{Binding HasImage, Converter={StaticResource InvertBool}}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <!-- Banner dots -->
                    <IndicatorView x:Name="bannerIndicator"
                                   HorizontalOptions="Center"
                                   IndicatorColor="#D1D8DB"
                                   SelectedIndicatorColor="#FF5722"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding Banners.Count, Converter={StaticResource IntToBool}}"/>

                    <!-- ── Rewards / Coupons Row ── -->
                    <Label Text="{loc:Loc Key=UseAndSave}"
                           FontFamily="CairoBold" FontSize="16" TextColor="#212121"
                           Margin="16,18,16,10"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="16,0">
                        <Border Grid.Column="0" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#F0F0F0"
                                StrokeThickness="1" Padding="16,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenRewardsCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="10">
                                <Border BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 20"
                                        Stroke="Transparent" WidthRequest="36" HeightRequest="36">
                                    <Label Text="🎁" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Rewards}"
                                       FontFamily="CairoBold" FontSize="15"
                                       TextColor="#212121" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="#F0F0F0"
                                StrokeThickness="1" Padding="16,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenCouponsCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="10">
                                <Border BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 20"
                                        Stroke="Transparent" WidthRequest="36" HeightRequest="36">
                                    <Label Text="🎟️" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{loc:Loc Key=Coupons}"
                                       FontFamily="CairoBold" FontSize="15"
                                       TextColor="#212121" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ── No Location Banner ── -->
                    <Border BackgroundColor="#FFF8E1"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#FFE082" StrokeThickness="1"
                            Padding="20,16" Margin="16,18,16,0"
                            IsVisible="{Binding HasLocation, Converter={StaticResource InvertBool}}">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="📍" FontSize="36" HorizontalOptions="Center"/>
                            <Label Text="{loc:Loc Key=TapToSetLocation}"
                                   FontFamily="CairoBold" FontSize="14"
                                   TextColor="#E65100"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="{loc:Loc Key=ChooseLocation}"
                                    Command="{Binding OpenLocationPickerCommand}"
                                    BackgroundColor="#FF5722"
                                    TextColor="White"
                                    FontFamily="CairoBold" FontSize="13"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Section Title ── -->
                    <Label Text="{Binding SectionTitle}"
                           FontFamily="CairoBold" FontSize="16" TextColor="#212121"
                           Margin="16,18,16,10"/>

                    <!-- ── Loading ── -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#FF5722" Margin="0,20"/>

                    <!-- ── Shops List (only when location set) ── -->
                    <CollectionView ItemsSource="{Binding Restaurants}"
                                    SelectionMode="None"
                                    Margin="16,0"
                                    IsVisible="{Binding HasLocation}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:Restaurant">
                                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenRestaurantCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="95,*" ColumnSpacing="14">

                                        <!-- Image -->
                                        <Border Grid.Column="0" BackgroundColor="#F0F0F0"
                                                StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                                HeightRequest="88" WidthRequest="95">
                                            <Grid>
                                                <Label Text="🍽️" FontSize="38"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       IsVisible="{Binding FullImageUrl, Converter={StaticResource HasImage}, ConverterParameter='invert'}"/>
                                                <ff:CachedImage Source="{Binding FullImageUrl}"
                                                               Aspect="AspectFill"
                                                               HeightRequest="88" WidthRequest="95"
                                                               CacheDuration="7"
                                                               IsVisible="{Binding FullImageUrl, Converter={StaticResource HasImage}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Info -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                       FontFamily="CairoBold" FontSize="15"
                                                       TextColor="#212121" LineBreakMode="TailTruncation"/>
                                                <Border Grid.Column="1"
                                                        StrokeShape="RoundRectangle 8"
                                                        Stroke="Transparent" Padding="7,3"
                                                        BackgroundColor="{Binding StatusBg}">
                                                    <Label Text="{Binding StatusText}"
                                                           TextColor="{Binding StatusColor}"
                                                           FontFamily="CairoBold" FontSize="10"/>
                                                </Border>
                                            </Grid>
                                            <Label Text="{Binding Description}"
                                                   FontFamily="CairoRegular" FontSize="12"
                                                   TextColor="#757575" MaxLines="1"
                                                   LineBreakMode="TailTruncation"/>
                                            <HorizontalStackLayout Spacing="10">
                                                <HorizontalStackLayout Spacing="3">
                                                    <Label Text="⭐" FontSize="12" VerticalOptions="Center"/>
                                                    <Label Text="{Binding RatingText}"
                                                           FontFamily="CairoBold" FontSize="12"
                                                           TextColor="#212121" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Spacing="3">
                                                    <Label Text="🕐" FontSize="12" VerticalOptions="Center"/>
                                                    <Label Text="{Binding EstimatedTimeText}"
                                                           FontFamily="CairoRegular" FontSize="12"
                                                           TextColor="#757575" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding DeliveryFeeText}"
                                                       FontFamily="CairoBold" FontSize="12"
                                                       TextColor="#FF5722"/>
                                                <Border BackgroundColor="#F5F5F5"
                                                        StrokeShape="RoundRectangle 6"
                                                        Stroke="Transparent" Padding="6,2"
                                                        IsVisible="{Binding DistanceKm, Converter={StaticResource IntToBool}}">
                                                    <Label FontFamily="CairoRegular" FontSize="11"
                                                           TextColor="#757575">
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="📍 "/>
                                                                <Span Text="{Binding DistanceKm, StringFormat='{0:F1} km'}"/>
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                </Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- ── Empty state ── -->
                    <VerticalStackLayout Spacing="8" Margin="16,30"
                                         HorizontalOptions="Center"
                                         IsVisible="{Binding HasNoResults}">
                        <Label Text="🔍" FontSize="44" HorizontalOptions="Center"/>
                        <Label Text="{loc:Loc Key=NoShopsNearby}"
                               FontFamily="CairoRegular" FontSize="14" TextColor="#9E9E9E"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ══ BOTTOM BAR ══ -->
        <controls:CurvedBottomBar Grid.Row="1" SelectedTab="home"
                                   HorizontalOptions="Fill" Margin="0" Padding="0"/>
    </Grid>
</ContentPage>
