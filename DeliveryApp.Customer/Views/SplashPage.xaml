<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.SplashPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#FF5722">
    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <!-- ✅ تم تغيير الاسم من logo-en.png إلى logo_en.png لتجنب خطأ أندرويد -->
            <Image x:Name="imgLogo"
       Aspect="AspectFill"
       HeightRequest="110"
       WidthRequest="110"
       HorizontalOptions="Center"
       VerticalOptions="Center"/>

            <Label Text="{loc:Loc Key=AppName}"
                   FontFamily="CairoBold" FontSize="42" TextColor="White" HorizontalOptions="Center"/>
            <Label Text="{loc:Loc Key=SplashSubtitle}"
                   FontFamily="CairoRegular" FontSize="15" TextColor="#FFCCBC" HorizontalOptions="Center"/>
        </VerticalStackLayout>
        <ActivityIndicator Color="White" IsRunning="True" VerticalOptions="End" Margin="0,0,0,60"/>
    </Grid>
</ContentPage>
