<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Customer.Models"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.OrderDetailPage"
             x:DataType="vm:OrderDetailViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Header with Back Button -->
        <Grid Grid.Row="0" Padding="16,52,16,12" ColumnDefinitions="44,*">
            <Image Grid.Column="0" Source="icon_back.png" WidthRequest="38" HeightRequest="38"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1" Text="{loc:Loc Key=OrderDetails}" FontFamily="CairoBold" FontSize="22"
                   TextColor="#212121" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Status -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Label FontFamily="CairoRegular" FontSize="14" TextColor="#757575">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{loc:Loc Key=OrderNumber}"/>
                                    <Span Text="{Binding OrderId}" FontAttributes="Bold" TextColor="#212121"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border StrokeShape="RoundRectangle 10" Stroke="Transparent" Padding="12,7"
                            HorizontalOptions="Start" BackgroundColor="{Binding Order.StatusColor}">
                            <Label Text="{Binding Order.StatusText}" TextColor="White" FontFamily="CairoBold" FontSize="13"/>
                        </Border>
                        <Label FontFamily="CairoRegular" FontSize="13" TextColor="#757575">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{loc:Loc Key=Placed}"/>
                                    <Span Text="{Binding Order.CreatedAt, StringFormat='{0:MMM dd, yyyy  HH:mm}'}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Items -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Loc Key=ItemsSectionTitle}" FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>
                        <BoxView Color="#E0E0E0" HeightRequest="1"/>
                        <CollectionView ItemsSource="{Binding Order.Items}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="m:OrderItem">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,5,0,5">
                                        <Label Grid.Column="0" FontFamily="CairoRegular" FontSize="14" TextColor="#212121">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Quantity}" FontAttributes="Bold"/>
                                                    <Span Text="×  "/>
                                                    <Span Text="{Binding ProductName}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label Grid.Column="1" Text="{Binding TotalPriceText}"
                                           FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <BoxView Color="#E0E0E0" HeightRequest="1"/>
                        <!-- Price Breakdown -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                            <Label Grid.Column="0" Text="المجموع الفرعي" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>
                            <Label Grid.Column="1" Text="{Binding Order.SubTotal, StringFormat='{0:F2} جنيه'}" FontFamily="CairoRegular" FontSize="14" TextColor="#212121"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                            <Label Grid.Column="0" Text="رسوم التوصيل" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>
                            <Label Grid.Column="1" Text="{Binding Order.DeliveryFee, StringFormat='{0:F2} جنيه'}" FontFamily="CairoRegular" FontSize="14" TextColor="#212121"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0" IsVisible="{Binding Order.Discount, Converter={StaticResource IntToBool}}">
                            <Label Grid.Column="0" Text="الخصم" FontFamily="CairoRegular" FontSize="14" TextColor="#4CAF50"/>
                            <Label Grid.Column="1" Text="{Binding Order.Discount, StringFormat='-{0:F2} جنيه'}" FontFamily="CairoRegular" FontSize="14" TextColor="#4CAF50"/>
                        </Grid>
                        <BoxView Color="#F0F0F0" HeightRequest="1" Margin="0,5"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{loc:Loc Key=Total}" FontFamily="CairoBold"
                               FontSize="16" TextColor="#212121"/>
                            <Label Grid.Column="1" Text="{Binding Order.TotalAmountText}"
                               FontFamily="CairoBold" FontSize="20" TextColor="#FF5722"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Cancel Button -->
                <Button Text="{loc:Loc Key=CancelOrder}" Command="{Binding CancelCommand}"
                    Style="{StaticResource OutlineBtn}"
                    IsVisible="{Binding Order.CanCancel}"/>

                <!-- Rate Button -->
                <Button Text="{loc:Loc Key=RateExperience}" Command="{Binding RateCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    IsVisible="{Binding Order.CanRate}"/>

                <!-- Rating Panel -->
                <Border Style="{StaticResource Card}" IsVisible="{Binding ShowRating}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{loc:Loc Key=RateOrder}" FontFamily="CairoBold" FontSize="18" TextColor="#212121"/>
                        <Label Text="{loc:Loc Key=RateRestaurant}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                        <Stepper Value="{Binding RestaurantRating}" Minimum="1" Maximum="5" Increment="1" HorizontalOptions="Start"/>
                        <Label Text="{loc:Loc Key=RateDriver}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                        <Stepper Value="{Binding DriverRating}" Minimum="1" Maximum="5" Increment="1" HorizontalOptions="Start"/>
                        <Border Style="{StaticResource InputBorder}" Padding="12">
                            <Editor Text="{Binding Comment}" Placeholder="{loc:Loc Key=CommentPlaceholder}"
                                FontFamily="CairoRegular" FontSize="14" HeightRequest="80"
                                BackgroundColor="Transparent"/>
                        </Border>
                        <Button Text="{loc:Loc Key=SubmitRating}" Command="{Binding SubmitRatingCommand}"
                            Style="{StaticResource PrimaryBtn}"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
