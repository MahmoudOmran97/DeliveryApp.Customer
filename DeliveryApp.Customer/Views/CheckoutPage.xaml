<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.CheckoutPage"
             x:DataType="vm:CheckoutViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Padding="16,52,16,12" ColumnDefinitions="44,*">
            <Image Grid.Column="0" Source="icon_back.png" WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1"
                   Text="{loc:Loc Key=Checkout}"
                   FontFamily="CairoBold" FontSize="22"
                   TextColor="#212121"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- ── Body ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,0" Spacing="14">

                <!-- عنوان التوصيل -->
                <Border BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="{loc:Loc Key=DeliveryAddress}"
                               FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>

                        <Entry Text="{Binding Address}"
                               Placeholder="{loc:Loc Key=AddressPlaceholder}"
                               HeightRequest="50"/>

                        <!-- أزرار اختيار الموقع -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" Padding="10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding UseCurrentLocationCommand}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="📍" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="{loc:Loc Key=UseCurrentLocation}"
                                           FontFamily="CairoBold" FontSize="12"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" StrokeShape="RoundRectangle 12"
                                    Stroke="#E0E0E0" Padding="10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PickLocationOnMapCommand}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="🗺️" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="{loc:Loc Key=PickAddressOnMap}"
                                           FontFamily="CairoBold" FontSize="12"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- تأكيد تحديد الموقع -->
                        <Border IsVisible="{Binding HasLocationSelected}"
                                BackgroundColor="#E8F5E9"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,6">
                            <Label Text="{loc:Loc Key=LocationConfirmed}"
                                   FontFamily="CairoRegular" FontSize="12"
                                   TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ملاحظات للمندوب -->
                <Border BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Loc Key=NotesForDriver}"
                               FontFamily="CairoBold" FontSize="15" TextColor="#212121"/>
                        <Editor Text="{Binding Notes}"
                                Placeholder="{loc:Loc Key=NotesPlaceholder}"
                                HeightRequest="80" AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ملخص الطلب -->
                <Border BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Loc Key=OrderSummary}"
                               FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>
                        <BoxView Color="#E0E0E0" HeightRequest="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{loc:Loc Key=Subtotal}"
                                   FontFamily="CairoRegular" FontSize="14" TextColor="#424242"/>
                            <Label Grid.Column="1" Text="{Binding SubTotal, StringFormat='{0:F2} EGP'}"
                                   FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{loc:Loc Key=DeliveryFee}"
                                   FontFamily="CairoRegular" FontSize="14" TextColor="#424242"/>
                            <Label Grid.Column="1" Text="{Binding DeliveryFee, StringFormat='{0:F2} EGP'}"
                                   FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
                        </Grid>

                        <BoxView Color="#E0E0E0" HeightRequest="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{loc:Loc Key=Total}"
                                   FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>
                            <Label Grid.Column="1" Text="{Binding Total, StringFormat='{0:F2} EGP'}"
                                   FontFamily="CairoBold" FontSize="16" TextColor="#FF5722"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- طريقة الدفع -->
                <Border BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Loc Key=PaymentMethod}"
                               FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="💵" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="{loc:Loc Key=CashOnDelivery}"
                                   FontFamily="CairoRegular" FontSize="14"
                                   TextColor="#424242" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="10" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── زر التأكيد ── -->
        <Button Grid.Row="2"
                Text="{loc:Loc Key=PlaceOrder}"
                Command="{Binding PlaceOrderCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource PrimaryBtn}"
                Margin="16,0,16,34"/>
    </Grid>

</ContentPage>
