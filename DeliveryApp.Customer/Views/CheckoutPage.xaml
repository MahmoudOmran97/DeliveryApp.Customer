<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.CheckoutPage"
             x:DataType="vm:CheckoutViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Padding="16,52,16,12" ColumnDefinitions="44,*">
            <Image Grid.Column="0" Source="icon_back.png" WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1" Text="الشيك أوت" FontFamily="CairoBold" FontSize="22" TextColor="#212121" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,0" Spacing="14">
                <Border BackgroundColor="White" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="📍 عنوان التوصيل" FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>
                        <Entry Text="{Binding Address}" Placeholder="أدخل العنوان بالتفصيل..." HeightRequest="50"/>

                        <Label Text="اختر طريقة تحديد الموقع:" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" Padding="10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding UseCurrentLocationCommand}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="📍" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="موقعي الحالي" FontFamily="CairoBold" FontSize="12" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="{Binding HasLocationSelected, Converter={StaticResource BoolToColorConverter}}" Padding="10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PickLocationOnMapCommand}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="🗺️" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="اختر من الخريطة" FontFamily="CairoBold" FontSize="12" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                        <Border IsVisible="{Binding HasLocationSelected}" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 8" Padding="10,6">
                            <Label Text="✅ تم تحديد الموقع بنجاح" FontFamily="CairoRegular" FontSize="12" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>
                <!-- باقي عناصر الصفحة مثل ملخص الطلب والفع والزر السفلي -->
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2" Text="تأكيد الطلب 🎉" Command="{Binding PlaceOrderCommand}" Style="{StaticResource PrimaryBtn}" Margin="16,0,16,34"/>
    </Grid>
</ContentPage>