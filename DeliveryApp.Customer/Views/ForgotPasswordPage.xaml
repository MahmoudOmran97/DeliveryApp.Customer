<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="28,56,28,40" Spacing="16">

            <HorizontalStackLayout>
                <Image Source="icon_back.png" WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
            </HorizontalStackLayout>

            <Label Text="{loc:Loc Key=ForgotPasswordTitle}" FontFamily="CairoBold" FontSize="28" TextColor="#212121"/>

            <!-- ── خطوة 1: إدخال الإيميل ────────────────────────────── -->
            <VerticalStackLayout IsVisible="{Binding IsNotOtpStep}" Spacing="16">

                <Label Text="{loc:Loc Key=EnterEmailToReset}" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=Email}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=EmailPlaceholder}" Text="{Binding Email}" Keyboard="Email"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"
                               ReturnCommand="{Binding SendCodeCommand}"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{loc:Loc Key=SendCode}" Command="{Binding SendCodeCommand}"
                        IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryBtn}" Margin="0,8,0,0"/>
            </VerticalStackLayout>

            <!-- ── خطوة 2: إدخال الكود وكلمة المرور الجديدة ────────────── -->
            <VerticalStackLayout IsVisible="{Binding IsOtpStep}" Spacing="16">

                <Label Text="{loc:Loc Key=EnterOtpAndNewPassword}" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=OtpCode}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=OtpPlaceholder}" Text="{Binding Otp}" Keyboard="Numeric"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=NewPassword}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=MinPasswordHint}" Text="{Binding NewPassword}" IsPassword="True"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=ConfirmPassword}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=ConfirmPasswordPlaceholder}" Text="{Binding ConfirmNewPassword}"
                               IsPassword="True" HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"
                               ReturnCommand="{Binding ResetPasswordCommand}"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{loc:Loc Key=ResetPassword}" Command="{Binding ResetPasswordCommand}"
                        IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryBtn}" Margin="0,8,0,0"/>

                <Label Text="{loc:Loc Key=ChangeEmail}" FontFamily="CairoBold" FontSize="14"
                       TextColor="#FF5722" HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditEmailCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#FF5722" HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
