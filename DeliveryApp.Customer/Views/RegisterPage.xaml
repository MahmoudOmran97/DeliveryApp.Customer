<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="28,56,28,40" Spacing="16">

            <HorizontalStackLayout>
                <Image Source="icon_back.png" WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
            </HorizontalStackLayout>

            <Label Text="{loc:Loc Key=CreateAccount}" FontFamily="CairoBold" FontSize="28" TextColor="#212121"/>
            <Label Text="{loc:Loc Key=FillDetails}" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>

            <!-- ── خطوة 1: بيانات الحساب ────────────────────────────────── -->
            <VerticalStackLayout IsVisible="{Binding IsNotOtpStep}" Spacing="16">

                <!-- Full Name -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=FullName}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=FullNamePlaceholder}" Text="{Binding FullName}"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=Email}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=EmailPlaceholder}" Text="{Binding Email}" Keyboard="Email"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Phone -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=PhoneNumber}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=PhonePlaceholder}" Text="{Binding Phone}" Keyboard="Telephone"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=Password}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=MinPasswordHint}" Text="{Binding Password}" IsPassword="True"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Confirm Password -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=ConfirmPassword}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=ConfirmPasswordPlaceholder}" Text="{Binding ConfirmPassword}"
                               IsPassword="True" HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"
                               ReturnCommand="{Binding SendOtpCommand}"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{loc:Loc Key=SendCode}" Command="{Binding SendOtpCommand}"
                        IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryBtn}" Margin="0,8,0,0"/>
            </VerticalStackLayout>

            <!-- ── خطوة 2: تأكيد كود التحقق ─────────────────────────────── -->
            <VerticalStackLayout IsVisible="{Binding IsOtpStep}" Spacing="16">

                <Label Text="{loc:Loc Key=EnterOtpAndNewPassword}" FontFamily="CairoRegular" FontSize="14" TextColor="#757575"/>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Loc Key=OtpCode}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>
                    <Border Style="{StaticResource InputBorder}">
                        <Entry Placeholder="{loc:Loc Key=OtpPlaceholder}" Text="{Binding Otp}" Keyboard="Numeric"
                               HeightRequest="50" BackgroundColor="Transparent"
                               FontFamily="CairoRegular" FontSize="15"
                               ReturnCommand="{Binding RegisterCommand}"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{loc:Loc Key=CreateAccount}" Command="{Binding RegisterCommand}"
                        IsEnabled="{Binding IsNotBusy}" Style="{StaticResource PrimaryBtn}" Margin="0,8,0,0"/>

                <Label Text="{loc:Loc Key=ChangeEmail}" FontFamily="CairoBold" FontSize="14"
                       TextColor="#FF5722" HorizontalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditDetailsCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#FF5722" HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="{loc:Loc Key=AlreadyHaveAccount}" FontFamily="CairoRegular" FontSize="14"
                       TextColor="#757575" VerticalOptions="Center"/>
                <Label Text="{loc:Loc Key=Login}" FontFamily="CairoBold" FontSize="14"
                       TextColor="#FF5722" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
