<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Customer.Models"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.CartPage"
             x:DataType="vm:CartViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,52,16,12" ColumnDefinitions="44,*,Auto">
            <ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         WidthRequest="38" HeightRequest="38"
                         BackgroundColor="Transparent"
                         VerticalOptions="Center"
                         Command="{Binding GoBackCommand}"/>
            <Label Grid.Column="1" Text="{loc:Loc Key=MyCart}" FontFamily="CairoBold" FontSize="22"
                   TextColor="#212121" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="2" Text="{loc:Loc Key=ClearAll}" FontFamily="CairoRegular" FontSize="13"
                   TextColor="#F44336" VerticalOptions="Center"
                   IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBool}}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ClearCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding IsEmpty}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="14">
            <Label Text="🛒" FontSize="72" HorizontalOptions="Center"/>
            <Label Text="{loc:Loc Key=CartEmpty}" FontFamily="CairoBold" FontSize="20"
                   TextColor="#212121" HorizontalOptions="Center"/>
            <Label Text="{loc:Loc Key=CartEmptySub}" FontFamily="CairoRegular" FontSize="14"
                   TextColor="#757575" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Items -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBool}}"
                        Margin="16,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:CartItem">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">

                            <!-- Product image placeholder -->
                            <Border Grid.Column="0" BackgroundColor="#F0F0F0"
                                    StrokeShape="RoundRectangle 10" Stroke="Transparent" HeightRequest="64">
                                <Label Text="🍛" FontSize="30"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <!-- Name + price -->
                            <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Label Text="{Binding Product.Name}"
                                       FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
                                <Label Text="{Binding TotalPriceText}"
                                       FontFamily="CairoBold" FontSize="14" TextColor="#FF5722"/>
                            </VerticalStackLayout>

                            <!-- ✅ Qty Controls — ImageButton works reliably inside CollectionView -->
                            <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">

                                <ImageButton Source="icon_minus.png"
                                             WidthRequest="34" HeightRequest="34"
                                             BackgroundColor="Transparent"
                                             Aspect="AspectFit"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartViewModel}}, Path=DecCommand}"
                                             CommandParameter="{Binding .}"/>

                                <Label Text="{Binding Quantity}"
                                       FontFamily="CairoBold" FontSize="18"
                                       TextColor="#212121"
                                       VerticalOptions="Center"
                                       WidthRequest="26"
                                       HorizontalTextAlignment="Center"/>

                                <ImageButton Source="icon_plus.png"
                                             WidthRequest="34" HeightRequest="34"
                                             BackgroundColor="Transparent"
                                             Aspect="AspectFit"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartViewModel}}, Path=IncCommand}"
                                             CommandParameter="{Binding .}"/>

                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer -->
        <Border Grid.Row="2" BackgroundColor="White" StrokeShape="RoundRectangle 24,24,0,0"
                Stroke="Transparent" Padding="20,18,20,34"
                IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBool}}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Opacity="0.07" Radius="14"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{loc:Loc Key=Total}" FontFamily="CairoRegular" FontSize="15"
                           TextColor="#757575" VerticalOptions="Center"/>
                    <Label Grid.Column="1" FontFamily="CairoBold" FontSize="22" TextColor="#FF5722">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Total, StringFormat='{0:F0}'}"/>
                                <Span Text=" EGP"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>
                <Button Text="{loc:Loc Key=ProceedToCheckout}"
                        Command="{Binding CheckoutCommand}"
                        Style="{StaticResource PrimaryBtn}"/>
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
