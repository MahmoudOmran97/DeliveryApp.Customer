<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Customer.ViewModels"
             xmlns:loc="clr-namespace:DeliveryApp.Customer.Converters"
             x:Class="DeliveryApp.Customer.Views.PointsPage"
             x:DataType="vm:PointsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- ══════ HEADER ══════ -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="20,52,20,20"
              ColumnDefinitions="44,*">
            <ImageButton Grid.Column="0" Source="icon_back.png"
                         Command="{Binding BackCommand}"
                         WidthRequest="38" HeightRequest="38"
                         BackgroundColor="Transparent"
                         VerticalOptions="Center"/>
            <Label Grid.Column="1" Text="{loc:Loc Key=Points}"
                   FontFamily="CairoBold" FontSize="20"
                   TextColor="White" VerticalOptions="Center"
                   HorizontalOptions="Center" Margin="0,0,38,0"/>
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="20">

                    <!-- ══════ POINTS BALANCE HERO CARD ══════ -->
                    <Border BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 24"
                            Stroke="Transparent"
                            Padding="24"
                            Shadow="{Shadow Brush=Black, Offset='0,8', Opacity=0.15, Radius=15}">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{loc:Loc Key=PointsBalanceLabel}"
                                       FontFamily="CairoRegular" FontSize="14"
                                       TextColor="#FFCCBC"/>
                                <Label Text="{Binding PointsBalance}"
                                       FontFamily="CairoBold" FontSize="42"
                                       TextColor="White"/>
                                <Label Text="{loc:Loc Key=PointsSubTitle}"
                                       FontFamily="CairoRegular" FontSize="12"
                                       TextColor="#FFCCBC"
                                       Margin="0,4,0,0"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="10">
                                <Label Text="✨" FontSize="48" HorizontalOptions="Center"/>
                                <Button Text="{loc:Loc Key=Redeem100Points}"
                                        Command="{Binding RedeemPointsCommand}"
                                        BackgroundColor="White"
                                        TextColor="{StaticResource Primary}"
                                        FontFamily="CairoBold"
                                        FontSize="13"
                                        Padding="16,0"
                                        HeightRequest="36"
                                        CornerRadius="18"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ══════ TABS / FILTERS ══════ -->
                    <Border BackgroundColor="White"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            Padding="4"
                            HeightRequest="56">
                        <Grid ColumnDefinitions="*,*,*">
                            <!-- All Tab -->
                            <Button Grid.Column="0" Text="{loc:Loc Key=Tab_All}"
                                    Command="{Binding FilterTransactionsCommand}" CommandParameter="All"
                                    BackgroundColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='All'}"
                                    TextColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='All_Text'}"
                                    FontFamily="CairoBold" FontSize="14" CornerRadius="12"/>

                            <!-- Earned Tab -->
                            <Button Grid.Column="1" Text="{loc:Loc Key=Tab_Earned}"
                                    Command="{Binding FilterTransactionsCommand}" CommandParameter="Earned"
                                    BackgroundColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='Earned'}"
                                    TextColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='Earned_Text'}"
                                    FontFamily="CairoBold" FontSize="14" CornerRadius="12"/>

                            <!-- Spent Tab -->
                            <Button Grid.Column="2" Text="{loc:Loc Key=Tab_Spent}"
                                    Command="{Binding FilterTransactionsCommand}" CommandParameter="Spent"
                                    BackgroundColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='Spent'}"
                                    TextColor="{Binding SelectedTab, Converter={StaticResource BoolToColor}, ConverterParameter='Spent_Text'}"
                                    FontFamily="CairoBold" FontSize="14" CornerRadius="12"/>
                        </Grid>
                    </Border>

                    <!-- ══════ TRANSACTIONS LIST ══════ -->
                    <Label Text="{loc:Loc Key=ViewHistory}" 
                           FontFamily="CairoBold" FontSize="18" 
                           TextColor="{StaticResource TextPrimary}"
                           Margin="4,10,0,0"/>

                    <CollectionView ItemsSource="{Binding FilteredTransactions}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60,0,0" Spacing="15">
                                <Label Text="📭" FontSize="60" HorizontalOptions="Center"/>
                                <Label Text="{loc:Loc Key=NoPointsFound}"
                                       FontFamily="CairoBold" FontSize="18"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PointTransaction">
                                <Grid Padding="0,0,0,12">
                                    <Border BackgroundColor="White"
                                            StrokeShape="RoundRectangle 16"
                                            Stroke="#F0F0F0"
                                            StrokeThickness="1"
                                            Padding="0">
                                        <Grid ColumnDefinitions="6, *, Auto">
                                            <!-- Color Indicator Strip -->
                                            <Border Grid.Column="0" 
                                                    BackgroundColor="{Binding Amount, Converter={StaticResource AmountToColor}}"
                                                    StrokeShape="RoundRectangle 16,0,0,16"
                                                    StrokeThickness="0"
                                                    WidthRequest="6"
                                                    HorizontalOptions="Start"/>

                                            <!-- Content -->
                                            <VerticalStackLayout Grid.Column="1" Padding="16,12" Spacing="4">
                                                <Label Text="{Binding Title}" 
                                                       FontFamily="CairoBold" FontSize="15" 
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="📅" FontSize="12" VerticalOptions="Center"/>
                                                    <Label Text="{Binding DateText}" 
                                                           FontFamily="CairoRegular" FontSize="12" 
                                                           TextColor="{StaticResource TextSecondary}"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Amount Banner -->
                                            <Border Grid.Column="2" 
                                                    Margin="12"
                                                    Padding="12,6"
                                                    BackgroundColor="{Binding Amount, Converter={StaticResource AmountToColor}, ConverterParameter='Light'}"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="Transparent"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding AmountText}"
                                                       FontFamily="CairoBold" FontSize="16"
                                                       TextColor="{Binding Amount, Converter={StaticResource AmountToColor}}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
